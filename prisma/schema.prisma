// Esquece Barber Studio — data model.
// See ARCHITECTURE.md #4-5 and BOOKING_RULES.md for the rules this schema supports.
//
// IMPORTANT: the actual double-booking guarantee is a Postgres EXCLUDE
// constraint (btree_gist) added via a hand-written SQL migration in Phase 2,
// not something Prisma's schema DSL can express. See ARCHITECTURE.md #5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  WEBSITE
  WHATSAPP
  ADMIN
}

enum ConversationState {
  IDLE
  SELECTING_SERVICE
  SELECTING_BARBER
  SELECTING_DATE
  SELECTING_TIME
  REQUESTING_NAME
  AWAITING_CONFIRMATION
  BOOKING_CONFIRMED
  HUMAN_HANDOFF
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum HandoffStatus {
  OPEN
  RESOLVED
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULE
  INTERNAL_ALERT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// --- Business ---

model Business {
  id              String   @id @default(cuid())
  name            String
  description     String?
  address         String?
  mapUrl          String?
  timezone        String   @default("America/La_Paz")
  phone           String?
  instagramHandle String?
  accentColorHex  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  settings     BusinessSettings?
  barbers      Barber[]
  services     Service[]
  blockedSlots BlockedSlot[]
  auditLogs    AuditLog[]
}

model BusinessSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  minLeadTimeMinutes     Int     @default(60)
  maxAdvanceDays         Int     @default(30)
  defaultBufferMinutes   Int     @default(0)
  slotStepMinutes        Int     @default(15)
  cancellationPolicyText String?
  reminderHoursBefore    Int[]   @default([24])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Barbers & services ---

model Barber {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  photoUrl     String?
  bio          String?
  specialties  String[]
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  services         BarberService[]
  workingSchedules WorkingSchedule[]
  breaks           Break[]
  timeOff          TimeOff[]
  blockedSlots     BlockedSlot[]
  appointments     Appointment[]

  @@index([businessId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  priceAmount     Decimal  @db.Decimal(10, 2)
  currency        String   @default("BOB")
  durationMinutes Int
  bufferMinutes   Int?
  imageUrl        String?
  isActive        Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barbers      BarberService[]
  appointments Appointment[]

  @@index([businessId])
}

model BarberService {
  id        String   @id @default(cuid())
  barberId  String
  serviceId String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([barberId, serviceId])
  @@index([serviceId])
}

// --- Availability inputs ---

model WorkingSchedule {
  id        String   @id @default(cuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0 = Sunday ... 6 = Saturday, matches JS Date#getDay()
  startTime String // "HH:mm", business-local time
  endTime   String // "HH:mm", business-local time
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barberId, dayOfWeek])
}

model Break {
  id        String    @id @default(cuid())
  barberId  String
  barber    Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int? // set for a recurring weekly break
  date      DateTime? @db.Date // set for a one-off break on a specific date
  startTime String // "HH:mm"
  endTime   String // "HH:mm"
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([barberId])
}

model TimeOff {
  id        String   @id @default(cuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barberId, startsAt, endsAt])
}

model BlockedSlot {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  barberId   String? // null = applies to the whole business
  barber     Barber?  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId, startsAt, endsAt])
  @@index([barberId, startsAt, endsAt])
}

// --- Customers & appointments ---

model Customer {
  id              String   @id @default(cuid())
  name            String?
  phone           String   @unique // normalized via lib/whatsapp/phone.ts, no "+"
  email           String?
  notes           String?
  createdAt       DateTime @default(now())
  lastInteraction DateTime @default(now())

  appointments  Appointment[]
  conversations Conversation[]

  @@index([phone])
}

model Appointment {
  id          String            @id @default(cuid())
  customerId  String
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  serviceId   String
  service     Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  barberId    String
  barber      Barber            @relation(fields: [barberId], references: [id], onDelete: Restrict)
  startTime   DateTime
  endTime     DateTime
  priceAmount Decimal           @db.Decimal(10, 2)
  currency    String
  status      AppointmentStatus @default(CONFIRMED)
  source      AppointmentSource
  comment     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  notifications Notification[]

  // This index speeds up the application-level overlap check only.
  // The actual race-condition guarantee is the Postgres EXCLUDE
  // constraint from a Phase 2 hand-written migration (ARCHITECTURE.md #5).
  @@index([barberId, startTime, endTime])
  @@index([customerId])
  @@index([status])
}

// --- Conversations (WhatsApp) ---

model Conversation {
  id                 String            @id @default(cuid())
  phone              String            @unique // normalized wa_id
  customerId         String?
  customer           Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  state              ConversationState @default(IDLE)
  scratchData        Json?
  humanHandoffActive Boolean           @default(false)
  lastMessageAt      DateTime          @default(now())
  sessionExpiresAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  messages      ConversationMessage[]
  stateLogs     ConversationStateLog[]
  handoffs      HumanHandoff[]
  notifications Notification[]

  @@index([phone])
}

model ConversationMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  externalId     String?          @unique // Meta's message id — dedup key, see WHATSAPP_AGENT_DESIGN.md #3
  direction      MessageDirection
  messageType    String // text, interactive, image, audio, location, etc.
  content        String?
  status         String? // sent/delivered/read/failed, from Meta status events
  rawTimestamp   String? // Meta's original timestamp, kept verbatim for auditing
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model ConversationStateLog {
  id             String            @id @default(cuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromState      ConversationState
  toState        ConversationState
  reason         String
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
}

model HumanHandoff {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reason         String
  status         HandoffStatus @default(OPEN)
  assignedTo     String? // free-text placeholder until an admin-user model exists (Phase 4)
  startedAt      DateTime      @default(now())
  reactivatedAt  DateTime?

  @@index([conversationId])
  @@index([status])
}

// --- Notifications & audit ---

model Notification {
  id             String             @id @default(cuid())
  appointmentId  String?
  appointment    Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  type           NotificationType
  scheduledAt    DateTime
  status         NotificationStatus @default(PENDING)
  attempts       Int                @default(0)
  sentAt         DateTime?
  lastError      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status, scheduledAt])
  @@index([appointmentId])
}

model AuditLog {
  id         String    @id @default(cuid())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  actorType  String // "admin" | "system" | "customer"
  actorId    String?
  action     String // e.g. "appointment.cancel"
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
