# Copy to .env and fill in real values locally. Never commit .env.
# See README.md, SECURITY.md, ARCHITECTURE.md.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Separate public website's origin, for CORS on the public booking API (Phase F).
# Leave empty until that project exists / has a domain.
PUBLIC_WEBSITE_ORIGIN=
BUSINESS_TIMEZONE=America/La_Paz
LOG_LEVEL=info
DEMO_MODE=true

# --- CRM (Google Apps Script + Sheets) ---
CRM_PROVIDER=mock
CRM_APPS_SCRIPT_URL=
CRM_API_KEY=
CRM_SIGNING_SECRET=
CRM_REQUEST_TIMEOUT_MS=12000
# Only ever set this to true for a deliberate demo deployment that is NOT
# serving real customers — never for a real Esquece production deployment.
ALLOW_UNSAFE_MOCKS_IN_PRODUCTION=false

# --- Anthropic (Claude API) ---
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Meta / WhatsApp Cloud API ---
WHATSAPP_PROVIDER=mock
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_API_VERSION=

# --- Admin auth (MVP, env-based — see SECURITY.md) ---
AUTH_SECRET=
ADMIN_EMAIL=
# Generate with: npm run hash-password -- "your-password"
# IMPORTANT if setting this in a .env/.env.local file (not needed on Render,
# which injects real process env vars): Next.js's env loader expands "$" as
# variable interpolation, and bcrypt hashes are full of "$2b$12$...". Escape
# every "$" as "\$" in a .env file or the hash will be silently corrupted and
# every login will fail with no useful error. Example of a correctly escaped
# line: ADMIN_PASSWORD_HASH=\$2b\$12\$abcdefghijklmnopqrstuv...
ADMIN_PASSWORD_HASH=

# --- Ops ---
CRON_SECRET=
INTERNAL_ALERT_PHONE=
INTERNAL_ALERT_EMAIL=

# --- WhatsApp templates (required outside the 24h customer-initiated window) ---
WHATSAPP_REMINDER_TEMPLATE_NAME=
WHATSAPP_REMINDER_TEMPLATE_LANGUAGE=es
WHATSAPP_CANCELLATION_TEMPLATE_NAME=
WHATSAPP_RESCHEDULE_TEMPLATE_NAME=
