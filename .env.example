# Copy to .env and fill in real values locally. Never commit .env.
# See README.md, SECURITY.md, ARCHITECTURE.md.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BUSINESS_TIMEZONE=America/La_Paz
LOG_LEVEL=info
DEMO_MODE=true

# --- CRM (Google Apps Script + Sheets) ---
CRM_PROVIDER=mock
CRM_APPS_SCRIPT_URL=
CRM_API_KEY=
CRM_SIGNING_SECRET=
CRM_REQUEST_TIMEOUT_MS=12000

# --- Anthropic (Claude API) ---
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Meta / WhatsApp Cloud API ---
WHATSAPP_PROVIDER=mock
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_API_VERSION=

# --- Admin auth (MVP, env-based — see SECURITY.md) ---
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# --- Ops ---
CRON_SECRET=
INTERNAL_ALERT_PHONE=
INTERNAL_ALERT_EMAIL=

# --- WhatsApp templates (required outside the 24h customer-initiated window) ---
WHATSAPP_REMINDER_TEMPLATE_NAME=
WHATSAPP_REMINDER_TEMPLATE_LANGUAGE=es
WHATSAPP_CANCELLATION_TEMPLATE_NAME=
WHATSAPP_RESCHEDULE_TEMPLATE_NAME=
